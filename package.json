{
  "name": "@fermin-dev/reins",
  "version": "0.3.0",
  "description": "Install and orchestrate a controlled multi-agent harness on top of an existing project, for Claude Code.",
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "subagents",
    "harness",
    "scaffold",
    "cli",
    "spec-driven-development"
  ],
  "type": "module",
  "license": "MIT",
  "author": "betta-tech",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EdwinFermin/reins.git"
  },
  "homepage": "https://github.com/EdwinFermin/reins#readme",
  "bugs": {
    "url": "https://github.com/EdwinFermin/reins/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "reins": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.19"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "clipanion": "^3.2.1",
    "diff": "^5.2.0",
    "eta": "^3.5.0",
    "execa": "^9.5.1",
    "jiti": "^2.4.0",
    "lilconfig": "^3.1.2",
    "smol-toml": "^1.3.1",
    "typanion": "^3.14.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/diff": "^5.2.3",
    "@types/node": "^22.9.1",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.5"
  }
}
